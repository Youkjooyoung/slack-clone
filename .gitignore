# ============================================================
#  Slack Clone — .gitignore
# ============================================================

# ── 환경변수 (절대 커밋 금지) ───────────────────────────────
.env
.env.local
.env.*.local

# ── Frontend ────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
# PWA 자동 생성 파일
frontend/public/sw.js
frontend/public/workbox-*.js
frontend/public/sw.js.map

# ── Backend ─────────────────────────────────────────────────
backend/build/
backend/.gradle/
backend/out/
backend/bin/
backend/*.class
# Gradle 래퍼 jar는 커밋 (필요)
!backend/gradle/wrapper/gradle-wrapper.jar
!backend/**/src/main/**/build/
!backend/**/src/test/**/build/

# ── Docker ──────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE ─────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
.factorypath
.classpath
.project
.settings/
.springBeans
.sts4-cache/
.apt_generated/

# ── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 테스트 / 커버리지 ────────────────────────────────────────
coverage/
.nyc_output/
frontend/.jest-cache/

# ── Claude Code / MCP (로컬 전용) ───────────────────────────
.claude/
.mcp.json
