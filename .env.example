# ============================================================
#  Slack Clone — 환경변수 예시
#  사용법: cp .env.example .env  →  실제 값으로 수정 후 실행
#  주의: .env 파일은 절대 Git에 커밋하지 마세요.
# ============================================================

# ── 서비스 포트 (변경 필요 시만 수정) ──────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=slackclone
POSTGRES_USER=slackclone
POSTGRES_PASSWORD=your_strong_password_here

# ── Redis ───────────────────────────────────────────────────
# 비워두면 인증 없음 (개발용). 운영 환경에서는 반드시 설정.
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────
# 256비트(32자) 이상의 랜덤 문자열 사용 권장
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-256-bits
JWT_EXPIRATION=900000        # 15분 (ms)
JWT_REFRESH_EXPIRATION=604800000  # 7일 (ms)

# ── AWS S3 ──────────────────────────────────────────────────
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=your-s3-bucket-name
# 버킷 리전 (application.yml aws.s3.region 과 일치해야 함)
# 기본값: ap-northeast-2 (서울)

# ── Frontend (Next.js) ──────────────────────────────────────
# Docker Compose 환경: 컨테이너 이름으로 통신
NEXT_PUBLIC_API_URL=http://backend:8080
NEXT_PUBLIC_SOCKET_URL=http://backend:8080

# 로컬 개발 환경 (docker-compose 없이 직접 실행 시):
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_SOCKET_URL=http://localhost:8080
